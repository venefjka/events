{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "baseUrl": null,
        "strict": true,
        "paths": {
            "@/*": [
                "./*"
            ]
        },
        "jsx": "react",
        "esModuleInterop": true,
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts"
    ]
}